@Article{duanAccurateDetectionAtrial2022,
  author   = {Duan, Junbo and Wang, Qing and Zhang, Bo and Liu, Chen and Li, Chenrui and Wang, Lei},
  title    = {Accurate detection of atrial fibrillation events with {R}-{R} intervals from {ECG} signals},
  doi      = {10.1371/journal.pone.0271596},
  issn     = {1932-6203},
  language = {en},
  note     = {Publisher: Public Library of Science},
  number   = {8},
  pages    = {e0271596},
  urldate  = {2024-07-24},
  volume   = {17},
  abstract = {Atrial fibrillation (AF) is a typical category of arrhythmia. Clinical diagnosis of AF is based on the detection of abnormal R-R intervals (RRIs) with an electrocardiogram (ECG). Previous studies considered this detection problem as a classification problem and focused on extracting a number of features. In this study we demonstrate that instead of using any specific numerical characteristic as the input feature, the probability density of RRIs from ECG conserves comprehensive statistical information; hence, is a natural and efficient input feature for AF detection. Incorporated with a support vector machine as the classifier, results on the MIT-BIH database indicates that the proposed method is a simple and accurate approach for AF detection in terms of accuracy, sensitivity, and specificity.},
  file     = {Full Text PDF:/home/apo-pc/Zotero/storage/7RKG5PWX/Duan et al. - 2022 - Accurate detection of atrial fibrillation events w.pdf:application/pdf},
  journal  = {PLOS ONE},
  keywords = {Arrhythmia, Atrial fibrillation, Database and informatics methods, Electrocardiography, Kernel functions, Probability density, Skewness, Support vector machines},
  month    = aug,
  year     = {2022},
}


